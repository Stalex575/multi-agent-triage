GOOGLE_API_KEY=replace-with-google-ai-studio-api-key
PINECONE_API_KEY=replace-with-pinecone-api-key

PINECONE_INDEX_NAME=multi-agent-triage
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_METRIC=cosine

PINECONE_CACHE_NAMESPACE=semantic-cache
PINECONE_DB_NAMESPACE=db-infra-context
PINECONE_DEVOPS_NAMESPACE=cloud-devops-context

GEMINI_HEAVY_MODEL=gemini-3.5-flash
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSION=3072

SEMANTIC_CACHE_THRESHOLD=0.92
MAX_QA_RETRIES=2
SPECIALIST_TOP_K=5
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
CACHE_TEXT_MAX_CHARS=20000

